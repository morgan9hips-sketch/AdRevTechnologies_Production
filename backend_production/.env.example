DATABASE_URL=postgresql://cashuser:cashpass@db:5432/cashforads
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me_refresh
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# PayPal Configuration
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_WEBHOOK_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4000/auth/facebook/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4000/auth/github/callback

# Ad Network Webhook Secrets (for HMAC verification)
WEBHOOK_SECRET_DEFAULT=your_default_webhook_secret_here
WEBHOOK_SECRET_ADMOB=
WEBHOOK_SECRET_UNITY_ADS=
WEBHOOK_SECRET_IRONSOURCE=
WEBHOOK_SECRET_APPLOVIN=

# Anti-Fraud Configuration
DUPLICATE_WATCH_WINDOW_HOURS=24
MAX_WATCHES_PER_HOUR=10
FRAUD_SCORE_THRESHOLD=75
PLATFORM_FEE_PERCENTAGE=0.1
MIN_PAYOUT_AMOUNT_CENTS=1000

# Email Configuration (SMTP)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cashforads.com

# Logging Configuration
LOG_DIR=logs

# Production Database (Optional - for Neon/Supabase)
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Stripe Configuration (SaaS Billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

